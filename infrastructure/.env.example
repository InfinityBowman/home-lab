# HomeLab PaaS — Environment Variables
# Copy this file to .env and fill in values:
#   cp .env.example .env

# ─── Domain ────────────────────────────────────────────────────────────────
# Base domain for app routing (apps get <name>.<BASE_DOMAIN>)
BASE_DOMAIN=jacobmaynard.dev

# ─── Security ──────────────────────────────────────────────────────────────
# Shared secret for API auth and git hook callbacks
# Generate with: openssl rand -hex 32
INTERNAL_HOOK_SECRET=

# ─── Cloudflare ────────────────────────────────────────────────────────────
# API token with Account:Cloudflare Tunnel:Edit + Zone:DNS:Edit permissions
CLOUDFLARE_API_TOKEN=

# Account ID (visible on your domain's Overview page)
CLOUDFLARE_ACCOUNT_ID=

# Zone ID (visible on your domain's Overview page)
CLOUDFLARE_ZONE_ID=

# Tunnel ID (from tunnel creation — see docs/cloudflare-tunnel-setup.md)
CLOUDFLARE_TUNNEL_ID=

# Tunnel token (from tunnel creation — used by cloudflared container)
CLOUDFLARE_TUNNEL_TOKEN=
