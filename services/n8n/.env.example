# Must match the BASE_DOMAIN in infrastructure/.env
BASE_DOMAIN=jacobmaynard.dev

# CRITICAL: Generate once and store safely. If lost, all saved credentials are unrecoverable.
# Generate with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=

# PostgreSQL password (no special characters)
N8N_POSTGRES_PASSWORD=

# Timezone for cron/scheduling
GENERIC_TIMEZONE=America/Chicago
